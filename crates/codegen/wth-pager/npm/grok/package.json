        "@wth-build/wth-darwin-x64": "0.1.0",
        "@wth-build/wth-linux-arm64": "0.1.0",
        "@wth-build/wth-linux-x64": "0.1.0",
        "@wth-build/wth-win32-arm64": "0.1.0",
        "@wth-build/wth-win32-x64": "0.1.0"
